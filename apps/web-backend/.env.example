# ── Django ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ── 推理后端 ────────────────────────────────────────────
# yolo = 真实 ultralytics 推理(生产默认,需装 torch/ultralytics + 放模型到 models/trained)
# demo = 免 torch 的演示后端(无模型/无 GPU 时用,仍出真实标注图)
INFER_BACKEND=yolo
INFER_DEVICE=cpu           # cpu / cuda:0 ...
MODEL_CACHE_SIZE=2         # 同时缓存的模型数(LRU)

# 可视化字体:留空用引擎内置字体;或指向系统 CJK 字体绝对路径(让标注中文正常显示)
VIZ_FONT_PATH=

# ── 大模型 ──────────────────────────────────────────────
# template = 无需密钥的结构化模板分析(默认);dashscope = 通义千问;openai = OpenAI
LLM_PROVIDER=template
LLM_MODEL=qwen-plus
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── 报告 PDF 引擎 ───────────────────────────────────────
# auto = 优先 WeasyPrint,缺系统库回退 xhtml2pdf;也可强制 weasyprint / xhtml2pdf
REPORT_PDF_ENGINE=auto

# ── 其它 ────────────────────────────────────────────────
MAX_BATCH_IMAGES=60
# 生产用 PostgreSQL 时取消注释:
# POSTGRES_DB=odplatform
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
